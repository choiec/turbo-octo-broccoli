# Copy to .env. Do not commit.
# Required for Docker / docker compose:

# Optional:
# API_PORT=8000
# SQLITE_PATH=./data/learner_portfolio.db
# DB_RESET_ON_STARTUP=false  # true: drop SQLite tables and recreate on each server start (dev only)

# Optional for FalkorDB:
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_GRAPH=knowledge_graph
# FALKORDB_BROWSER_PORT=3000

# Required for OpenAI:
# OPENAI_API_KEY=sk-...

# Required for Entra ID OAuth:
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=

# Required for GitHub:
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
